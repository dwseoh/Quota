{
  "name": "quota",
  "displayName": "Quota",
  "description": "Track and optimize costs in your codebase",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:go",
    "onLanguage:java"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "quota.showCostDetails",
        "title": "Show Cost Details"
      },
      {
        "command": "quota.updateUserCount",
        "title": "Update User Count for Simulation",
        "icon": "$(edit)"
      },
      {
        "command": "quota.refresh",
        "title": "Refresh Cost Analysis",
        "icon": "$(refresh)"
      },
      {
        "command": "quota.toggleMockData",
        "title": "Toggle Mock Data (Testing)"
      },
      {
        "command": "quota.showCallDetails",
        "title": "Show Call Details"
      },
      {
        "command": "quota.showSuggestionDetails",
        "title": "Show Optimization Suggestion Details"
      },
      {
        "command": "quota.jumpToCall",
        "title": "Jump to LLM Call"
      },
      {
        "command": "quota.jumpToSuggestion",
        "title": "Jump to Optimization Suggestion"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "quota-sidebar",
          "title": "Quota",
          "icon": "media/logo.svg"
        }
      ]
    },
    "views": {
      "quota-sidebar": [
        {
          "id": "quota-panel",
          "name": "Quota",
          "icon": "media/logo.svg"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "quota.refresh",
          "when": "view == quota-panel",
          "group": "navigation"
        },
        {
          "command": "quota.updateUserCount",
          "when": "view == quota-panel",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "quota.showCallDetails",
          "when": "view == quota-panel && viewItem == call_item",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Quota",
      "properties": {
        "quota.monthlyBudget": {
          "type": "number",
          "default": 500,
          "description": "Monthly budget limit in USD for cost alerts"
        },
        "quota.enhancedAiClassification": {
          "type": "boolean",
          "default": false,
          "description": "After quick import-based detection, use Gemini on ambiguous units (unknown provider). Slower; requires GEMINI_API_KEY."
        },
        "quota.enhancedAiMaxUnits": {
          "type": "number",
          "default": 40,
          "minimum": 0,
          "maximum": 500,
          "description": "Max code units per index run sent to Gemini when enhanced AI is on (0 disables Gemini calls)."
        }
      }
    },
    "colors": [
      {
        "id": "quota.icon.critical",
        "description": "Color for critical impact items",
        "defaults": {
          "dark": "#AD46FF",
          "light": "#8000FF",
          "highContrast": "#FF00FF"
        }
      },
      {
        "id": "quota.icon.high",
        "description": "Color for high impact items",
        "defaults": {
          "dark": "#FFD700",
          "light": "#FFD700",
          "highContrast": "#FFD700"
        }
      },
      {
        "id": "quota.icon.normal",
        "description": "Color for normal/low impact items",
        "defaults": {
          "dark": "#00BFFF",
          "light": "#007ACC",
          "highContrast": "#0000FF"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build:wasm": "tree-sitter build --wasm node_modules/tree-sitter-java -o wasm/tree-sitter-java.wasm",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.108.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "tree-sitter-cli": "^0.26.7",
    "tree-sitter-java": "^0.23.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@typescript-eslint/parser": "^8.52.0",
    "dotenv": "^17.2.3",
    "web-tree-sitter": "^0.26.7"
  }
}
